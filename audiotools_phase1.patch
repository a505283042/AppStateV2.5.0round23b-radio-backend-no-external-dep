+static int file_source_read(void* ctx, uint8_t* dst, size_t bytes)
+{
+  AudioFile* f = static_cast<AudioFile*>(ctx);
+  if (!f || !dst || bytes == 0) return AUDIO_MP3_SOURCE_ERROR;
+  int n = f->read(dst, bytes);
+  if (n > 0) return n;
+  return AUDIO_MP3_SOURCE_EOF;
+}
 
+static void file_source_close(void* ctx)
+{
+  AudioFile* f = static_cast<AudioFile*>(ctx);
+  if (f) f->close();
+}
 
