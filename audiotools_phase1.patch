+    size_t w = audio_i2s_write_frames(g_pcm, s_pending_frames);
+    if (w == SIZE_MAX) { audio_mp3_stop(); return false; }
+    s_pending_off    += w;
+    s_pending_frames -= w;
+  }
+
+  return true;
 }
